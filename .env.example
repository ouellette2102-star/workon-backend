# ==========================================
# WORKON BACKEND — EXEMPLE DE CONFIG
# Copier vers .env.local et remplir les valeurs
# ==========================================

# DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/workon?schema=public"

# APPLICATION
NODE_ENV="development"
PORT=3001

# JWT
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-refresh-in-production-min-32-chars"
JWT_REFRESH_EXPIRES_IN="30d"

# CLERK (optionnel en dev)
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""

# STRIPE
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SENTRY (optionnel — monitoring d'erreurs)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# CORS
CORS_ORIGIN="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# RATE LIMITING
RATE_LIMIT_ENABLED=1
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# SIGNED URLS (photos)
SIGNED_URL_SECRET="change-me-in-production"

# ==========================================
# HORS-APP SYSTEM (GHL + N8N)
# ==========================================

# N8N — URL de base pour les webhooks sortants
N8N_WEBHOOK_BASE=https://n8n-production-9b4ce.up.railway.app

# GHL — Secret partagé pour valider les webhooks entrants
# Configurer dans GHL: Settings → Webhooks → Custom Headers → x-ghl-secret
GHL_WEBHOOK_SECRET=workon-ghl-2026

# CRON — Secret pour protéger les endpoints cron automatisés
# Utilisé par Railway Cron ou N8N pour appeler /api/v1/scheduling/cron/*
CRON_SECRET=change-me-in-production
