generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditEvent {
  id         String   @id
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([resource, resourceId])
  @@index([userId])
  @@map("audit_events")
}

model Category {
  id                 String                     @id
  name               String                     @unique
  nameEn             String?
  icon               String?
  legalNotes         String?
  residentialAllowed Boolean                    @default(true)
  createdAt          DateTime                   @default(now())
  missions           Mission[]
  skills             Skill[]
  recurringTemplates RecurringMissionTemplate[] // PR-10

  @@map("categories")
}

model ClientOrg {
  id                 String             @id
  ownerId            String
  type               ClientOrgType
  name               String
  logoUrl            String?
  billingAddress     Json?
  taxNumbers         Json?
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime
  owner              User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  missions           Mission[]

  @@index([ownerId])
  @@map("client_orgs")
}

model ComplianceDocument {
  id         String                 @id
  userId     String
  type       ComplianceDocumentType
  version    String
  acceptedAt DateTime
  createdAt  DateTime               @default(now())
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([userId])
  @@map("compliance_documents")
}

// PR-07: Legal Compliance - Terms & Conditions Versioning
model TermsVersion {
  id          String                 @id @default(cuid())
  type        ComplianceDocumentType
  version     String // Semantic versioning: "1.0.0", "1.1.0", etc.
  title       String // Human-readable title
  contentUrl  String // URL to full document (PDF/HTML)
  contentHash String? // SHA256 hash for integrity verification
  summary     String? // Brief summary of changes
  effectiveAt DateTime // When this version becomes active
  createdAt   DateTime               @default(now())
  isActive    Boolean                @default(false) // Only one active per type

  @@unique([type, version])
  @@index([type, isActive])
  @@index([effectiveAt])
  @@map("terms_versions")
}

// PR-07: Legal Compliance - User Consent Tracking
model UserConsent {
  id          String      @id @default(cuid())
  userId      String
  consentType ConsentType
  granted     Boolean     @default(false)
  grantedAt   DateTime?
  revokedAt   DateTime?
  ipAddress   String? // IP when consent was given/revoked
  userAgent   String? // Browser/device info
  source      String? // Where consent was collected (signup, settings, etc.)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, consentType])
  @@index([userId])
  @@index([consentType])
  @@map("user_consents")
}

enum ConsentType {
  MARKETING_EMAIL // Marketing emails
  MARKETING_PUSH // Marketing push notifications
  ANALYTICS // Analytics and tracking
  THIRD_PARTY_SHARING // Sharing data with partners
  PERSONALIZATION // Personalized recommendations
}

model Dispute {
  id              String        @id
  missionId       String?       @unique
  localMissionId  String? // Link to native LocalMission
  openedById      String? // Clerk User ID (legacy)
  localOpenedById String? // LocalUser ID (native system)
  reason          String
  status          DisputeStatus @default(OPEN)
  resolution      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  mission         Mission?      @relation(fields: [missionId], references: [id], onDelete: Cascade)
  openedBy        User?         @relation(fields: [openedById], references: [id], onDelete: Cascade)
  localOpenedBy   LocalUser?    @relation("dispute_local_opener", fields: [localOpenedById], references: [id], onDelete: SetNull)

  // PR-00: Trust foundation relations
  evidence DisputeEvidence[]
  timeline DisputeTimeline[]

  @@index([status])
  @@map("disputes")
}

model LocalMission {
  id                    String             @id
  title                 String
  description           String
  category              String
  status                LocalMissionStatus @default(open)
  price                 Float
  latitude              Float
  longitude             Float
  city                  String
  address               String?
  createdByUserId       String
  assignedToUserId      String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime
  // PR-6: Payment fields
  paidAt                DateTime?
  stripePaymentIntentId String?
  // Lead tracking
  leadId                String?
  clientName            String?
  clientPhone           String?
  clientEmail           String?
  // Phase 3: Boosts (paid visibility/urgency)
  boostedUntil          DateTime?
  isUrgent              Boolean            @default(false)
  urgentUntil           DateTime?
  // Relations
  assignedToUser        LocalUser?         @relation("local_missions_assignedToUserIdTolocal_users", fields: [assignedToUserId], references: [id])
  createdByUser         LocalUser          @relation("local_missions_createdByUserIdTolocal_users", fields: [createdByUserId], references: [id], onDelete: Cascade)
  offers                LocalOffer[]
  messages              LocalMessage[]
  contract              Contract?          @relation("local_contracts")
  reviews               Review[]           @relation("review_mission")
  boosts                Boost[]

  @@index([assignedToUserId])
  @@index([category])
  @@index([city])
  @@index([createdByUserId])
  @@index([latitude, longitude])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@index([boostedUntil])
  @@index([isUrgent, urgentUntil])
  @@map("local_missions")
}

// ============================================
// BOOSTS — one-shot paid visibility/urgency upgrades
// ============================================

enum BoostType {
  URGENT_9          // +9 CAD: flag mission urgent for 24h + push to nearby pros
  TOP_48H_14        // +14 CAD: top of map / swipe stack for 48h
  VERIFY_EXPRESS_19 // +19 CAD: ID verification reviewed within 24h
}

enum BoostStatus {
  PENDING       // PaymentIntent created, not yet paid
  PAID          // payment_intent.succeeded — boost applied
  FAILED        // payment failed
  REFUNDED      // refunded later (rare)
}

model Boost {
  id                    String       @id
  userId                String
  missionId             String?      // null for VERIFY_EXPRESS_19 (account-level)
  type                  BoostType
  amountCents           Int
  currency              String       @default("CAD")
  stripePaymentIntentId String       @unique
  status                BoostStatus  @default(PENDING)
  appliedAt             DateTime?
  expiresAt             DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  mission LocalMission? @relation(fields: [missionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([missionId])
  @@index([status])
  @@index([type])
  @@map("boosts")
}

// ============================================
// LOCAL MESSAGES - Chat for LocalUser system
// ============================================

enum LocalMessageRole {
  WORKER
  EMPLOYER
}

enum LocalMessageStatus {
  SENT
  DELIVERED
  READ
}

model LocalMessage {
  id             String             @id
  missionId      String?
  conversationId String?
  senderId       String
  senderRole     LocalMessageRole
  content        String
  status         LocalMessageStatus @default(SENT)
  createdAt      DateTime           @default(now())

  mission      LocalMission?  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  conversation Conversation?  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       LocalUser      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("local_messages")
}

// ============================================
// CONVERSATIONS - Thread de chat pur (post-swipe-match)
// ============================================

enum ConversationUnlock {
  SWIPE_MATCH
}

model Conversation {
  id              String   @id
  participantAId  String
  participantBId  String
  unlockedVia     ConversationUnlock @default(SWIPE_MATCH)
  unlockedMatchId String?  @unique
  lastMessageAt   DateTime?
  createdAt       DateTime @default(now())

  messages LocalMessage[]

  @@unique([participantAId, participantBId])
  @@index([participantAId])
  @@index([participantBId])
  @@map("conversations")
}

// ============================================
// LOCAL DEVICES - Push notification tokens
// ============================================

model LocalDevice {
  id        String   @id @default(cuid())
  userId    String
  platform  String // "ios", "android", "web"
  token     String // FCM or APNs token
  name      String? // Device name
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user LocalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId, active])
  @@map("local_devices")
}

// ============================================
// SWIPE - Talent discovery (Tinder model)
// ============================================

model SwipeAction {
  id        String   @id @default(cuid())
  userId    String
  targetId  String
  action    String // "like", "pass", "superlike"
  createdAt DateTime @default(now())

  user LocalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
  @@index([userId])
  @@index([targetId])
  @@map("swipe_actions")
}

model SwipeMatch {
  id        String    @id @default(cuid())
  userAId   String
  userBId   String
  missionId String? // Mission created from match
  matchedAt DateTime  @default(now())
  expiresAt DateTime?
  status    String    @default("active") // "active", "expired", "converted"

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@map("swipe_matches")
}

// ============================================
// PRO MEDIA - Portfolio photos/videos
// ============================================

model ProMedia {
  id        String   @id @default(cuid())
  userId    String
  url       String
  type      String   @default("image") // "image", "video"
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user LocalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("pro_media")
}

// ============================================
// LEADS - Inbound lead tracking
// ============================================

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

model Lead {
  id          String     @id @default(cuid())
  userId      String? // Assigned worker (legacy — use deliveries table for new flow)
  source      String? // "ghl", "web", "referral", "apollo", "facebook"
  name        String
  email       String?
  phone       String?
  city        String?
  category    String?
  description String?
  status      LeadStatus @default(NEW)
  notes       String?

  // Phase 4: geo + category targeting for dispatch to subscribers
  latitude    Float?
  longitude   Float?
  categoryId  String?
  budgetCents Int?

  convertedToMissionId String?   @unique
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user        LocalUser?       @relation(fields: [userId], references: [id])
  deliveries  LeadDelivery[]

  @@index([userId])
  @@index([status])
  @@index([source])
  @@index([categoryId])
  @@index([latitude, longitude])
  @@map("leads")
}

model LeadDelivery {
  id                   String    @id @default(cuid())
  leadId               String
  deliveredToUserId    String
  deliveredAt          DateTime  @default(now())
  openedAt             DateTime?
  acceptedAt           DateTime?
  declinedAt           DateTime?
  convertedToMissionId String?

  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  deliveredTo LocalUser @relation("lead_delivery_target", fields: [deliveredToUserId], references: [id], onDelete: Cascade)

  @@unique([leadId, deliveredToUserId])
  @@index([deliveredToUserId])
  @@index([leadId])
  @@index([deliveredAt])
  @@map("lead_deliveries")
}

// ============================================
// LOCAL OFFERS - Offres pour missions locales
// ============================================

model LocalOffer {
  id        String           @id
  missionId String
  workerId  String
  price     Float
  message   String?
  status    LocalOfferStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime

  // Relations
  mission LocalMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  worker  LocalUser    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  // Unique constraint: one offer per worker per mission
  @@unique([missionId, workerId])
  @@index([missionId])
  @@index([workerId])
  @@index([status])
  @@map("local_offers")
}

enum LocalOfferStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// PR-06: Identity Verification Enums
enum IdVerificationStatus {
  NOT_STARTED // User hasn't initiated verification
  PENDING // Verification in progress
  VERIFIED // Successfully verified
  FAILED // Verification failed
  EXPIRED // Verification expired, needs renewal
}

enum TrustTier {
  BASIC // Default: email verified only
  VERIFIED // Phone verified
  TRUSTED // Phone + ID verified
  PREMIUM // Phone + ID + Bank verified (for workers)
}

model LocalUser {
  id             String        @id
  email          String        @unique
  hashedPassword String
  firstName      String
  lastName       String
  phone          String?
  city           String?
  pictureUrl     String? // Profile picture URL
  role           LocalUserRole @default(worker)
  active         Boolean       @default(true)
  deletedAt      DateTime? // GDPR: timestamp of account deletion
  createdAt      DateTime      @default(now())
  updatedAt      DateTime

  // PR-06: Identity Verification Hooks
  // Phone verification
  phoneVerified   Boolean   @default(false)
  phoneVerifiedAt DateTime?

  // ID verification (government ID, passport, etc.)
  idVerificationStatus   IdVerificationStatus @default(NOT_STARTED)
  idVerifiedAt           DateTime?
  idVerificationProvider String? // e.g., "stripe_identity", "jumio"
  idVerificationRef      String? // External reference ID

  // Bank verification (via Stripe)
  bankVerified    Boolean   @default(false)
  bankVerifiedAt  DateTime?
  stripeAccountId String? // Stripe Connect account ID

  // Trust tier (computed from verifications)
  trustTier          TrustTier @default(BASIC)
  trustTierUpdatedAt DateTime?

  // PR-07: Legal Compliance - Terms & Consent
  termsAcceptedAt    DateTime? // When user accepted current terms
  termsVersion       String? // Version of terms accepted (e.g., "1.0.0")
  privacyAcceptedAt  DateTime? // When user accepted privacy policy
  privacyVersion     String? // Version of privacy policy accepted
  marketingConsent   Boolean   @default(false) // Marketing communications
  marketingConsentAt DateTime? // When marketing consent was given/revoked

  // PR-07: Data Retention & GDPR/Loi 25
  dataRetentionConsent  Boolean   @default(true) // Consent to retain data
  dataExportRequestedAt DateTime? // Last data export request (GDPR Art. 20)
  dataExportCompletedAt DateTime? // When last export was completed
  deletionRequestedAt   DateTime? // When deletion was requested
  deletionScheduledFor  DateTime? // When data will be deleted (30-day grace)

  // Worker profile fields
  bio               String?
  slug              String?  @unique
  category          String? // Primary service category
  serviceRadiusKm   Float? // Service radius in km
  completionScore   Float?   @default(0) // Profile completion %
  latitude          Float? // GPS location
  longitude         Float? // GPS location
  gallery           String[] @default([]) // Portfolio image URLs
  skills            String[] @default([]) // Selected skill IDs from catalog
  hourlyRate        Float?    // Worker's base hourly rate in CAD (nullable)
  jobTitle          String?   // Short free-text title ("Peintre résidentiel", "Mover pro")
  trustScore           Float?    // Computed trust score
  trustScoreUpdatedAt  DateTime? // Last trust score recalculation
  ratingAverage        Float?    // Average review rating
  reviewCount          Int       @default(0)
  completedMissionsCount Int     @default(0)
  insuranceVerified    Boolean   @default(false)

  // Relations
  assignedMissions LocalMission[] @relation("local_missions_assignedToUserIdTolocal_users")
  createdMissions  LocalMission[] @relation("local_missions_createdByUserIdTolocal_users")
  offers           LocalOffer[]
  sentMessages     LocalMessage[]
  devices          LocalDevice[]
  receivedReviews  Review[]       @relation("review_target")
  authoredReviews  Review[]       @relation("review_author")
  swipeActions     SwipeAction[]
  proMedia         ProMedia[]
  leads            Lead[]
  leadDeliveries   LeadDelivery[] @relation("lead_delivery_target")
  subscriptions    Subscription[]

  @@index([active])
  @@index([city])
  @@index([email])
  @@index([role])
  @@index([slug])
  @@index([category])
  @@index([deletedAt])
  @@index([trustTier])
  @@index([phoneVerified])
  @@index([idVerificationStatus])
  @@index([deletionScheduledFor])
  notifications LocalNotification[]
  contractsAsEmployer Contract[] @relation("contracts_localEmployer")
  contractsAsWorker   Contract[] @relation("contracts_localWorker")
  disputesOpened      Dispute[]  @relation("dispute_local_opener")

  @@map("local_users")
}

model LocalNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String // "mission_accepted", "new_offer", "payment_received", "new_message", etc.
  title     String
  body      String
  data      Json? // arbitrary payload (missionId, offerId, etc.)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user LocalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("local_notifications")
}

model Mission {
  id               String         @id
  authorClientId   String
  assigneeWorkerId String?
  clientOrgId      String?
  title            String
  description      String
  categoryId       String
  requiredSkills   String[]       @default([])
  locationLat      Float
  locationLng      Float
  locationAddress  String?
  priceType        String
  budgetMin        Float
  budgetMax        Float
  status           MissionStatus  @default(DRAFT)
  startAt          DateTime?
  endAt            DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  deletedAt        DateTime?
  workerProfileId  String?
  dispute          Dispute?
  assigneeWorker   User?          @relation("missions_assigneeWorkerIdTousers", fields: [assigneeWorkerId], references: [id])
  authorClient     User           @relation("missions_authorClientIdTousers", fields: [authorClientId], references: [id], onDelete: Cascade)
  category         Category       @relation(fields: [categoryId], references: [id])
  clientOrg        ClientOrg?     @relation(fields: [clientOrgId], references: [id])
  workerProfile    WorkerProfile? @relation(fields: [workerProfileId], references: [id])
  offers           Offer[]
  payments         Payment[]
  reviews          Review[]
  messages         Message[]
  contract         Contract?
  photos           MissionPhoto[]
  events           MissionEvent[]

  @@index([assigneeWorkerId])
  @@index([authorClientId])
  @@index([categoryId])
  @@index([deletedAt])
  @@index([locationLat, locationLng])
  @@index([status])
  @@index([workerProfileId])
  @@map("missions")
}

model Notification {
  id          String    @id
  userId      String
  type        String
  payloadJSON Json
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([readAt])
  @@index([userId])
  @@map("notifications")
}

model Offer {
  id            String        @id
  missionId     String
  workerId      String
  message       String?
  proposedRate  Float
  eta           String?
  status        OfferStatus   @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  mission       Mission       @relation(fields: [missionId], references: [id], onDelete: Cascade)
  workerProfile WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@index([status])
  @@index([workerId])
  @@map("offers")
}

model Payment {
  id                     String        @id
  missionId              String        @unique
  stripePaymentIntentId  String?       @unique
  stripeConnectAccountId String?
  amountCents            Int
  currency               String        @default("CAD")
  platformFeePct         Float         @default(15)
  status                 PaymentStatus @default(CREATED)
  lastStripeEventId      String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime
  mission                Mission       @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@index([status])
  @@map("payments")
}

model Review {
  id                String           @id
  authorId          String?
  localAuthorId     String?
  targetUserId      String?
  localTargetUserId String?
  missionId         String?
  localMissionId    String?
  rating            Int
  comment           String?
  moderation        ReviewModeration @default(OK)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime
  author            User?            @relation("reviews_authorIdTousers", fields: [authorId], references: [id], onDelete: Cascade)
  localAuthor       LocalUser?       @relation("review_author", fields: [localAuthorId], references: [id], onDelete: Cascade)
  mission           Mission?         @relation(fields: [missionId], references: [id])
  localMission      LocalMission?    @relation("review_mission", fields: [localMissionId], references: [id], onDelete: SetNull)
  targetUser        User?            @relation("reviews_targetUserIdTousers", fields: [targetUserId], references: [id], onDelete: Cascade)
  localTargetUser   LocalUser?       @relation("review_target", fields: [localTargetUserId], references: [id])

  @@index([missionId])
  @@index([localMissionId])
  @@index([moderation])
  @@index([authorId])
  @@index([localAuthorId])
  @@index([targetUserId])
  @@index([localTargetUserId])
  @@map("reviews")
}

model Skill {
  id             String        @id
  name           String
  nameEn         String?
  categoryId     String
  requiresPermit Boolean       @default(false)
  proofType      String?
  createdAt      DateTime      @default(now())
  category       Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  workerSkills   WorkerSkill[]

  @@unique([name, categoryId])
  @@map("skills")
}

model Subscription {
  id                   String             @id
  userId               String
  plan                 SubscriptionPlan   @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  startedAt            DateTime           @default(now())
  currentPeriodEnd     DateTime?
  renewsAt             DateTime?
  canceledAt           DateTime?
  status               SubscriptionStatus @default(ACTIVE)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime
  user                 LocalUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  events               SubscriptionEvent[]

  @@index([status])
  @@index([userId])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model SubscriptionEvent {
  id             String       @id @default(cuid())
  subscriptionId String
  stripeEventId  String       @unique
  type           String
  processedAt    DateTime     @default(now())
  payload        Json

  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("subscription_events")
}

model UserProfile {
  id        Int      @id @default(autoincrement())
  userId    String   @unique
  role      UserRole
  name      String
  phone     String
  city      String
  createdAt DateTime @default(now())
  updatedAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model User {
  id                      String                   @id
  clerkId                 String                   @unique
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime
  auditEvents             AuditEvent[]
  clientOrgs              ClientOrg[]
  complianceDocuments     ComplianceDocument[]
  disputes                Dispute[]
  assignedMissions        Mission[]                @relation("missions_assigneeWorkerIdTousers")
  authoredMissions        Mission[]                @relation("missions_authorClientIdTousers")
  notifications           Notification[]
  authoredReviews         Review[]                 @relation("reviews_authorIdTousers")
  receivedReviews         Review[]                 @relation("reviews_targetUserIdTousers")
  userProfile             UserProfile?
  workerProfile           WorkerProfile?
  sentMessages            Message[]
  employerContracts       Contract[]               @relation("contracts_employerIdTousers")
  workerContracts         Contract[]               @relation("contracts_workerIdTousers")
  devices                 Device[]
  consents                UserConsent[] // PR-07: User consent tracking
  bookings                Booking[]                @relation("bookings_clientIdTousers") // PR-10
  notificationPreferences NotificationPreference[] // PR-12: Notification preferences
  notificationQueue       NotificationQueue[] // PR-12: Queued notifications
  notificationDeliveries  NotificationDelivery[] // PR-12: Delivery logs

  @@map("users")
}

/// Device registration for push notifications
model Device {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String // Unique device identifier (vendor ID, etc.)
  platform   String // ios, android, web
  pushToken  String? // FCM/APNs token
  appVersion String?
  active     Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([active])
  @@map("devices")
}

model WorkerProfile {
  id                 String                     @id
  userId             String                     @unique
  hourlyRate         Float
  serviceAreas       Json?
  residentialEnabled Boolean                    @default(false)
  portfolio          Json[]                     @default([])
  availability       Json?
  completedMissions  Int                        @default(0)
  totalEarnings      Float                      @default(0)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime
  missions           Mission[]
  offers             Offer[]
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerSkills       WorkerSkill[]
  // PR-10: Scheduling relations
  recurringTemplates RecurringMissionTemplate[]
  availabilitySlots  AvailabilitySlot[]
  bookings           Booking[]

  @@map("worker_profiles")
}

model WorkerSkill {
  id            String        @id
  workerId      String
  skillId       String
  verified      Boolean       @default(false)
  proofUrl      String?
  createdAt     DateTime      @default(now())
  skill         Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  workerProfile WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, skillId])
  @@map("worker_skills")
}

